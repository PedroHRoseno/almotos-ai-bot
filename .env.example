# Servidor
HOST=0.0.0.0
PORT=8000
DEBUG=false

# WhatsApp Business (Meta Cloud API)
WHATSAPP_VERIFY_TOKEN=seu_token_de_verificacao_do_webhook
WHATSAPP_ACCESS_TOKEN=seu_token_de_acesso_da_meta
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id
WHATSAPP_API_VERSION=v21.0

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# API principal de veículos (AlMotos)
# Use /vehicles (paginado; requer VEHICLES_API_TOKEN com JWT de admin)
# Se sua API expuser catálogo público em outro path, ajuste aqui.
VEHICLES_API_URL=https://api.almotoscaruaru.com.br/vehicles
VEHICLES_API_TOKEN=seu_jwt_do_painel_admin
VEHICLES_API_PAGE_SIZE=50
